PORT=3000
NODE_ENV=production
FRONTEND_URL=https://あなたのURL.onrender.com

JWT_SECRET=ここに64文字以上のランダム文字列を入れる

STRIPE_SECRET_KEY=sk_live_ここにStripeシークレットキー
STRIPE_PUBLISHABLE_KEY=pk_live_ここにStripe公開キー
STRIPE_WEBHOOK_SECRET=whsec_ここにWebhookシークレット
STRIPE_PRICE_STANDARD=price_ここにスタンダードの価格ID
STRIPE_PRICE_PREMIUM=price_ここにプレミアムの価格ID

ANTHROPIC_API_KEY=sk-ant-ここにAnthropicのAPIキー

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=あなたのGmailアドレス
SMTP_PASS=Gmailのアプリパスワード16桁
MAIL_FROM="豊洲ライフナビ <あなたのGmailアドレス>"

DB_DIR=./data
